<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Abdiel Life Sciences</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Lottie Animation -->
    <script src="https://unpkg.com/@@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
</head>

<body>

    <!-- INTRO SCREEN -->
    <div id="intro-screen">

        <div class="intro-container text-center">

            <lottie-player src="https://assets2.lottiefiles.com/packages/lf20_jcikwtux.json"
                           background="transparent"
                           speed="1"
                           style="width:200px;height:200px;"
                           autoplay>
            </lottie-player>

            <h1 class="intro-title">Abdiel Life Sciences</h1>

        </div>

    </div>


    <!-- HEADER -->
    <header>

        <nav class="navbar navbar-expand-lg shadow-sm">

            <div class="container">

                <a class="navbar-brand" href="/">
                    @* <img src="/images/logo.png" height="40" /> *@
                    <img src="https://cdn-icons-png.flaticon.com/512/2966/2966484.png" height="40" />
                </a>

                <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" href="/">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/About">About</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Product">Products</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Contact">Contact</a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>


    <!-- PAGE CONTENT -->
    <main>@RenderBody()</main>


    <!-- FOOTER -->
    <footer class="mt-5">

        <div class="container text-center p-4">

            <p>© 2026 Abdiel Life Sciences</p>

        </div>

    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        /* INTRO FADE OUT */

        window.onload = function () {

            setTimeout(function () {

                const intro = document.getElementById("intro-screen");

                intro.style.opacity = "0";
                intro.style.transition = "opacity 1s";

                setTimeout(function () {
                    intro.style.display = "none";
                }, 1000);

            }, 2500);

        };

    </script>

</body>
</html>
